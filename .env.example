# Copy this file to .env and insert your real keys

# Downstream Target API (OpenAI or your Antigravity Endpoint)
TARGET_API_URL=https://api.openai.com/v1/chat/completions

# OAuth2 Interactive Configuration
OAUTH_CLIENT_ID=your_client_id
OAUTH_AUTHORIZE_URL=https://auth.yourcompany.com/oauth2/authorize
OAUTH_TOKEN_URL=https://auth.yourcompany.com/oauth2/token
OAUTH_REDIRECT_URI=http://localhost:3001/callback

# ─── Claude Codex dashboard ────────────────────────────────────────
# Active workspace root. The dashboard's chat tool harness, fs API
# and exec API anchor every relative path here. Defaults to
# `/workspace` in Docker (see Dockerfile + docker-compose.yml) and
# the parent of the cwd when running outside Docker.
CLAUDE_CODEX_WORKSPACE=/workspace

# Parent directory under which the dashboard's "+ New workspace"
# button creates fresh project directories. Operators mount a host
# folder here when running in Docker so multiple workspaces persist
# across restarts.
CLAUDE_CODEX_WORKSPACES_DIR=/workspace

